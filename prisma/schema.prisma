generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model Review {
  id        String       @id @default(cuid())
  name      String
  company   String
  quote     String
  rating    Int
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([status, createdAt])
}